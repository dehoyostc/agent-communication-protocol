{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-communication-protocol.org/schemas/carp/agent-relationship-v0.2.schema.json",
  "title": "CARP Agent Relationship v0.2",
  "description": "Profile-level epistemic context describing how the agent came to know the entity.",
  "type": "object",
  "required": [
    "relationship_depth",
    "primary_observation_modes"
  ],
  "properties": {
    "relationship_depth": {
      "type": "string",
      "enum": [
        "longitudinal",
        "transactional",
        "document_based",
        "hybrid",
        "unknown"
      ]
    },
    "relationship_duration": {
      "type": [
        "string",
        "null"
      ]
    },
    "primary_observation_modes": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "entity_authorized": {
      "type": "boolean"
    },
    "last_reviewed_by_entity_at": {
      "anyOf": [
        {
          "type": "string",
          "format": "date-time"
        },
        {
          "type": "null"
        }
      ]
    },
    "notes": {
      "type": [
        "string",
        "null"
      ]
    }
  },
  "additionalProperties": false
}
